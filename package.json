{
  "name": "german-law-lookup",
  "version": "0.1.4",
  "description": "Look up German federal law references and insert formatted law text into notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "tsc -p tsconfig.test.json && node --test \"test-dist/**/*.test.js\""
  },
  "keywords": [
    "obsidian",
    "german-law"
  ],
  "author": "GammaFunds",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.5",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.7.3"
  }
}
